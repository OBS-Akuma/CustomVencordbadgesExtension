{
  "manifest_version": 3,
  "name": "Global Discord Badges",
  "version": "1.0.0",
  "description": "Shows custom badges from various mods in Discord",
  "permissions": ["storage"],
  "host_permissions": ["https://discord.com/*", "https://raw.githubusercontent.com/*"],
  "content_scripts": [{
    "matches": ["https://discord.com/*"],
    "js": ["content.js"],
    "css": ["styles.css"],
    "run_at": "document_idle"
  }],
  "web_accessible_resources": [{
    "resources": ["inject.js"],
    "matches": ["https://discord.com/*"]
  }]
}
